      </tbody>
    </table>
    <div style="margin-top:10px;font-size:11px;color:var(--muted);">📊 周级目标 {{ section_11.overall_target }} 篇 (含周报/Gap)，本周 {{ section_11.overall_actual }}/{{ section_11.overall_target }} = <span class="{{ section_11.overall_rate_class }}">{{ section_11.overall_rate }}</span> 整体达成率</div>
  </div>

  <div class="two-col">
    <div class="chart-card">
      <div class="chart-title">内容产出 (目标 14 篇/周)</div>
      <div class="metrics-grid" style="grid-template-columns:1fr 1fr;gap:10px;">
        <div class="metric-card {% if section_11.news_actual >= section_11.news_target %}green{% elif section_11.news_actual > 0 %}amber{% else %}red{% endif %}"><div class="m-label">SEO 新闻稿</div><div class="m-value">{{ section_11.news_actual }}</div><div class="m-sub">目标 {{ section_11.news_target }} 篇 ({{ section_11.news_gap_pct }})</div></div>
        <div class="metric-card {% if section_11.intent_actual >= section_11.intent_target %}green{% elif section_11.intent_actual > 0 %}amber{% else %}red{% endif %}"><div class="m-label">商业意图</div><div class="m-value">{{ section_11.intent_actual }}</div><div class="m-sub">目标 {{ section_11.intent_target }} 篇 ({{ section_11.intent_gap_pct }})</div></div>
      </div>
    </div>
    <div class="chart-card">
      <div class="chart-title">选题池状态</div>
      {% if section_11.topic_pool._error %}
      <div style="font-size:12px;color:var(--amber);">⚠️ 选题池 fetch error</div>
      {% else %}
      <div class="metrics-grid" style="grid-template-columns:1fr 1fr;gap:10px;">
        <div class="metric-card pw"><div class="m-label">候选总数</div><div class="m-value">{{ section_11.topic_pool.candidates_total }}</div></div>
        <div class="metric-card {% if section_11.topic_pool.low_stock_alert %}red{% else %}amber{% endif %}"><div class="m-label">待选题</div><div class="m-value">{{ section_11.topic_pool.waiting }}</div><div class="m-sub">已写双站 {{ section_11.topic_pool.written_both }} / PK {{ section_11.topic_pool.written_pk }} / FL {{ section_11.topic_pool.written_fl }}</div></div>
        <div class="metric-card {% if section_11.topic_pool.new_this_week > 0 %}green{% else %}red{% endif %}"><div class="m-label">本周新增</div><div class="m-value">{{ section_11.topic_pool.new_this_week }}</div></div>
        <div class="metric-card {% if section_11.topic_pool.consumed_this_week > 0 %}green{% else %}red{% endif %}"><div class="m-label">本周消费</div><div class="m-value">{{ section_11.topic_pool.consumed_this_week }}</div></div>
      </div>
      {% endif %}
    </div>
  </div>

  {% set rate_num = section_11.overall_actual / section_11.overall_target if section_11.overall_target > 0 else 0 %}
  {% if rate_num < 0.5 %}
  <div class="callout">
    <div class="callout-title">⚠️ SEO 产能严重不足</div>
    <div class="callout-body">本周仅产出 <strong>{{ section_11.overall_actual }} 篇</strong> (目标 {{ section_11.overall_target }} 篇，{{ section_11.overall_rate }})。{% if section_11.summary.stale_workflows %}<strong>{{ section_11.summary.stale_workflows | length }} 个工作流 Stale</strong>。{% endif %}<strong>首要任务：检查 n8n cron 触发状态 + 工作流执行日志。</strong></div>
  </div>
  {% endif %}
  {% if insights_html.get('11') %}<div class="callout">{{ insights_html['11'] | safe }}</div>{% endif %}
  {% endif %}
</div>

<!-- ===== 12 LIGHTHOUSE ⭐ NEW ===== -->
<div class="section" id="lighthouse">
  <div class="section-header"><span class="section-tag">12</span><span class="section-title">页面性能 Lighthouse ⭐ 新增 (模块 L)</span><div class="section-line"></div></div>
  {% if section_12._missing %}
  <div class="note-box"><strong>⚠️ 数据缺口</strong>: PSI collector 失败 (检查 PSI_API_KEY env 或 Google Cloud quota)。</div>
  {% else %}

  <div class="chart-card">
    <div class="chart-title">4 大维度评分 (移动端)</div>
    <table class="diff-table">
      <thead><tr><th>页面</th><th>Performance</th><th>Accessibility</th><th>Best Practices</th><th>SEO</th></tr></thead>
      <tbody>
        {% for r in section_12.score_rows %}
        {% if r._error %}
        <tr><td><strong>{{ r.name }}</strong></td><td colspan="4" style="color:var(--amber);font-size:12px;">⚠️ {{ r._error }}</td></tr>
        {% else %}
        <tr><td><strong>{{ r.name }}</strong></td><td class="mono {{ r.performance_class }}">{{ r.performance_emoji }} {{ r.performance }}</td><td class="mono {{ r.accessibility_class }}">{{ r.accessibility_emoji }} {{ r.accessibility }}</td><td class="mono {{ r.best_practices_class }}">{{ r.best_practices_emoji }} {{ r.best_practices }}</td><td class="mono {{ r.seo_class }}">{{ r.seo_emoji }} {{ r.seo }}</td></tr>
        {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>

  <div class="chart-card">
    <div class="chart-title">Performance 6 子项数值</div>
    <table class="diff-table">
      <thead><tr><th>指标</th><th>权重</th>{% for r in section_12.score_rows %}<th>{{ r.name | replace('Powkong', 'PK') | replace('Funlab', 'FL') }}</th>{% endfor %}</tr></thead>
      <tbody>
        {% for m in section_12.metric_rows %}
        <tr><td>{{ m.label }}</td><td class="mono">{{ m.weight }}</td>{% for c in m.cells %}<td class="mono {{ c.class }}">{{ c.value }}</td>{% endfor %}</tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <div class="chart-card">
    <div class="chart-title">Top 3 优化建议 (按预估节省时间 · 跨 4 页合并)</div>
    {% if section_12.top3 %}
    <ul style="margin-left:20px;line-height:2;">
      {% for o in section_12.top3 %}
      <li><strong>{{ o.page }}</strong>: {{ o.title }} - 节省 <span class="num-red">{{ '{:,}'.format(o.savings_ms) }}ms</span></li>
      {% endfor %}
    </ul>
    {% else %}
    <div style="font-size:12px;color:var(--muted);">无可优化项 (各页均已达到 best practices)</div>
    {% endif %}
  </div>

  {% if section_12.worst_lcp > 4000 %}
  <div class="note-box"><strong>⚡ 性能告警</strong>：{{ section_12.worst_lcp_page }} LCP {{ '{:,}'.format(section_12.worst_lcp) }}ms (目标 &lt; 2,500ms)，严重拖累用户体验和 SEO。Performance 平均 {{ section_12.perf_avg }}/100，<strong>{{ section_12.red_flags_count }} 个红灯指标</strong>。</div>
  {% endif %}
  {% if insights_html.get('12') %}<div class="callout">{{ insights_html['12'] | safe }}</div>{% endif %}
  {% endif %}
</div>

<!-- ===== 08 ACTION ITEMS ===== -->
<div class="section" id="action">
  <div class="section-header"><span class="section-tag">08</span><span class="section-title">下周任务清单</span><div class="section-line"></div></div>
  {% if section_08._missing %}
  <div class="note-box"><strong>⚠️ AI 任务清单未生成</strong>：integrator markdown 未输出 ## 08 段 (检查 DeepSeek API 调用)。回退到通用提示：<strong>登录飞书查看本周报，按 02-12 各段 callout 自定提优先级。</strong></div>
  {% else %}
  <div class="callout" style="background:rgba(99,102,241,0.06);border-color:rgba(99,102,241,0.2);border-left-color:var(--blue);">
    <div class="callout-title" style="color:var(--blue);">AI 综合任务清单 (DeepSeek 基于本周全数据生成)</div>
    <div class="callout-body action-md">{{ section_08.html | safe }}</div>
  </div>
  {% endif %}
</div>

<!-- FOOTER -->
<div class="report-footer">
  <div>双品牌运营周报 · {{ week_label }} · {{ date_range_start }} ~ {{ date_range_end }}</div>
  <div>数据来源：Shopify · Shopline · GA4 · GSC · Meta Ads · Google Ads (待 Token) · KOL 营销库 · n8n executions · PSI</div>
  <div>自动生成 by dtc-weekly module · 生成 {{ generated_at }}{% if gaps_count > 0 %} · ⚠️ {{ gaps_count }} collectors gaps{% endif %}</div>
</div>

</div>
</body>
</html>
