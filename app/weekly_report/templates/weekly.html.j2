<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>双品牌运营周报 {{ week_label }} · {{ date_range_start }} ~ {{ date_range_end }}</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Noto+Sans+SC:wght@300;400;500;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0c10; --surface: #111318; --surface2: #171b22;
  --border: rgba(255,255,255,0.07); --border2: rgba(255,255,255,0.12);
  --text: #e8eaf0; --muted: #6b7280;
  --blue: #3b82f6; --blue-dim: rgba(59,130,246,0.15);
  --green: #10b981; --green-dim: rgba(16,185,129,0.15);
  --amber: #f59e0b; --amber-dim: rgba(245,158,11,0.15);
  --red: #ef4444; --red-dim: rgba(239,68,68,0.15);
  --teal: #06b6d4; --purple: #8b5cf6;
  --pw: #FF9D00; --fl: #9900FF;
  --pw-soft: #FFB347; --fl-soft: #FC678A;
  --pw-glow: rgba(255,157,0,0.15); --fl-glow: rgba(153,0,255,0.15);
  --fb: #1877F2; --ig: #E4405F; --tt: #FE2C55; --yt: #FF0000; --x: #1DA1F2;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body { background: var(--bg); color: var(--text); font-family: 'Noto Sans SC', sans-serif; font-size: 14px; line-height: 1.6; min-height: 100vh; }
.shell { max-width: 1280px; margin: 0 auto; padding: 0 24px 80px; }

/* HEADER */
.report-header { border-bottom: 1px solid var(--border); padding: 40px 0 32px; margin-bottom: 40px; display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
.header-left h1 { font-family: 'Space Grotesk', sans-serif; font-size: 28px; font-weight: 700; letter-spacing: -0.5px; color: #fff; }
.header-left h1 span { color: var(--blue); }
.header-meta { display: flex; gap: 16px; margin-top: 10px; flex-wrap: wrap; }
.meta-pill { display: inline-flex; align-items: center; gap: 6px; padding: 4px 12px; border-radius: 20px; border: 1px solid var(--border2); background: var(--surface); font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); }
.meta-pill .dot { width: 6px; height: 6px; border-radius: 50%; }
.header-right { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); text-align: right; line-height: 1.8; }

/* NAV */
.sticky-nav { position: sticky; top: 0; z-index: 100; background: rgba(10,12,16,0.92); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); padding: 0 24px; margin: 0 -24px 40px; }
.nav-inner { max-width: 1280px; margin: 0 auto; display: flex; gap: 0; overflow-x: auto; scrollbar-width: none; }
.nav-inner::-webkit-scrollbar { display: none; }
.nav-link { display: flex; align-items: center; gap: 6px; padding: 14px 18px; font-size: 12px; font-family: 'DM Mono', monospace; color: var(--muted); text-decoration: none; border-bottom: 2px solid transparent; white-space: nowrap; transition: all 0.15s; }
.nav-link:hover { color: var(--text); }
.nav-link.pw:hover { color: var(--pw); border-bottom-color: var(--pw); }
.nav-link.fl:hover { color: var(--fl); border-bottom-color: var(--fl); }
.nav-dot { width: 6px; height: 6px; border-radius: 50%; }

/* SECTION */
.section { margin-bottom: 48px; }
.section-header { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
.section-tag { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); padding: 3px 10px; border: 1px solid var(--border); border-radius: 4px; }
.section-title { font-family: 'Space Grotesk', sans-serif; font-size: 18px; font-weight: 600; color: #fff; }
.section-line { flex: 1; height: 1px; background: var(--border); }
.brand-pw { color: var(--pw); }
.brand-fl { color: var(--fl); }

/* METRICS GRID */
.metrics-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; }
.metric-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 18px 20px; position: relative; overflow: hidden; transition: border-color 0.2s; }
.metric-card:hover { border-color: var(--border2); }
.metric-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--accent, var(--blue)); opacity: 0.6; }
.metric-card.pw { --accent: var(--pw); }
.metric-card.fl { --accent: var(--fl); }
.metric-card.amber { --accent: var(--amber); }
.metric-card.green { --accent: var(--green); }
.metric-card.red { --accent: var(--red); }
.m-label { font-size: 11px; color: var(--muted); margin-bottom: 8px; font-family: 'DM Mono', monospace; letter-spacing: 0.04em; }
.m-value { font-family: 'Space Grotesk', sans-serif; font-size: 26px; font-weight: 700; color: #fff; line-height: 1; margin-bottom: 6px; }
.m-value.sm { font-size: 20px; }
.m-sub { font-size: 12px; color: var(--muted); }
.m-badge { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; font-family: 'DM Mono', monospace; padding: 2px 8px; border-radius: 4px; margin-top: 4px; }
.badge-up { background: var(--green-dim); color: var(--green); }
.badge-down { background: var(--red-dim); color: var(--red); }
.badge-neutral { background: var(--amber-dim); color: var(--amber); }
.badge-info { background: var(--blue-dim); color: var(--blue); }

/* SHOPIFY CALLOUT */
.shopify-callout { background: linear-gradient(135deg, rgba(255,157,0,0.08) 0%, rgba(153,0,255,0.08) 100%); border: 1px solid var(--border2); border-radius: 14px; padding: 20px 24px; margin-bottom: 24px; }
.shopify-callout .row { display: flex; gap: 32px; flex-wrap: wrap; }
.s-label { font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace; margin-bottom: 3px; }
.s-val { font-family: 'Space Grotesk', sans-serif; font-size: 22px; font-weight: 700; }
.s-delta { font-size: 12px; font-family: 'DM Mono', monospace; margin-top: 2px; }

/* CHART CARD */
.chart-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 20px 24px; margin-bottom: 16px; }
.chart-title { font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 600; color: #fff; margin-bottom: 16px; }
.chart-subtitle { font-size: 12px; color: var(--muted); margin-bottom: 16px; }

/* BAR ROWS */
.bar-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; font-size: 12px; }
.bar-label { width: 100px; color: var(--muted); flex-shrink: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.bar-bg { flex: 1; background: rgba(255,255,255,0.05); border-radius: 3px; height: 10px; }
.bar-fill { height: 10px; border-radius: 3px; }
.bar-val { width: 65px; text-align: right; font-family: 'DM Mono', monospace; color: var(--text); }

/* ROAS DAY */
.roas-day { display: flex; align-items: center; gap: 8px; margin-bottom: 9px; }
.roas-date { width: 36px; font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); }
.roas-bg { flex: 1; background: rgba(255,255,255,0.05); border-radius: 3px; height: 18px; }
.roas-fill { height: 18px; border-radius: 3px; display: flex; align-items: center; padding-left: 8px; font-family: 'DM Mono', monospace; font-size: 11px; }
.roas-num { width: 36px; text-align: right; font-family: 'DM Mono', monospace; font-size: 12px; font-weight: 500; }

/* FUNNEL */
.funnel-step { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.funnel-label { width: 60px; font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace; }
.funnel-bg { flex: 1; background: rgba(255,255,255,0.05); border-radius: 3px; height: 24px; }
.funnel-fill { height: 24px; border-radius: 3px; display: flex; align-items: center; padding: 0 10px; font-size: 11px; font-family: 'DM Mono', monospace; }
.funnel-num { width: 60px; text-align: right; font-family: 'DM Mono', monospace; font-size: 12px; color: var(--text); }

/* DIFF TABLE */
.diff-table { width: 100%; border-collapse: collapse; }
.diff-table th { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); padding: 8px 12px; text-align: left; border-bottom: 1px solid var(--border); }
.diff-table td { padding: 10px 12px; border-bottom: 1px solid rgba(255,255,255,0.04); font-size: 13px; vertical-align: middle; }
.diff-table tr:last-child td { border-bottom: none; }
.diff-table td.mono { font-family: 'DM Mono', monospace; }
.diff-table td.up { color: var(--green); font-family: 'DM Mono', monospace; }
.diff-table td.down { color: var(--red); font-family: 'DM Mono', monospace; }
.diff-table tr:hover td { background: rgba(255,255,255,0.02); }

/* INSIGHT CARD */
.insight-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 12px; }
.insight-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 16px 20px; }
.insight-brand { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-bottom: 10px; }
.insight-item { display: flex; gap: 8px; padding: 6px 0; font-size: 13px; border-bottom: 1px solid rgba(255,255,255,0.04); line-height: 1.5; }
.insight-item:last-child { border-bottom: none; }
.insight-icon { flex-shrink: 0; margin-top: 2px; }

/* PROGRESS BAR (indexing) */
.index-bar-bg { background: rgba(255,255,255,0.06); border-radius: 4px; height: 16px; overflow: hidden; }

/* CALLOUT */
.callout { background: var(--amber-dim); border: 1px solid rgba(245,158,11,0.2); border-left: 4px solid var(--amber); border-radius: 8px; padding: 14px 18px; margin: 16px 0; }
.callout.kpi { background: rgba(139,92,246,0.06); border-color: rgba(139,92,246,0.2); border-left-color: var(--purple); }
.callout.kpi .callout-title { color: var(--purple); }
.callout-title { font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 600; color: var(--amber); margin-bottom: 6px; }
.callout-body { font-size: 13px; color: var(--text); line-height: 1.7; }
.callout-body strong { color: #fff; }

/* NOTE BOX */
.note-box { background: rgba(239,68,68,0.07); border: 1px solid rgba(239,68,68,0.2); border-radius: 10px; padding: 12px 16px; font-size: 13px; margin-bottom: 16px; }
.note-box strong { font-weight: 600; color: var(--red); }

/* GRID HELPERS */
.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.three-col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
@media (max-width: 800px) { .two-col, .three-col { grid-template-columns: 1fr; } }

/* FOOTER */
.report-footer { border-top: 1px solid var(--border); padding: 24px 0; display: flex; justify-content: space-between; align-items: center; font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); flex-wrap: wrap; gap: 8px; }

/* Number highlight */
.num-green { color: var(--green); }
.num-red { color: var(--red); }
.num-amber { color: var(--amber); }
.num-blue { color: var(--blue); }
</style>
</head>
<body>
<div class="shell">

<!-- HEADER -->
<div class="report-header">
  <div class="header-left">
    <h1>双品牌运营周报 <span>{{ week_label }}</span></h1>
    <div class="header-meta">
      <span class="meta-pill"><span class="dot" style="background:var(--pw)"></span>Powkong</span>
      <span class="meta-pill"><span class="dot" style="background:var(--fl)"></span>FUNLAB</span>
      <span class="meta-pill">{{ date_range_cn }}</span>
    </div>
  </div>
  <div class="header-right">
    生成时间 {{ generated_at }}<br>
    自动生成 by dtc-weekly module
  </div>
</div>

<!-- NAV -->
<div class="sticky-nav">
  <div class="nav-inner">
    <a href="#overview" class="nav-link">总览</a>
    <a href="#powkong" class="nav-link pw"><span class="nav-dot" style="background:var(--pw)"></span>PK 站</a>
    <a href="#powkong-products" class="nav-link pw"><span class="nav-dot" style="background:var(--pw)"></span>PK 产品</a>
    <a href="#powkong-fb" class="nav-link pw"><span class="nav-dot" style="background:var(--pw)"></span>PK Meta</a>
    <a href="#powkong-google" class="nav-link pw"><span class="nav-dot" style="background:var(--pw)"></span>PK Google Ads</a>
    <a href="#powkong-seo" class="nav-link pw"><span class="nav-dot" style="background:var(--pw)"></span>PK SEO</a>
    <a href="#funlab" class="nav-link fl"><span class="nav-dot" style="background:var(--fl)"></span>FL 站</a>
    <a href="#funlab-products" class="nav-link fl"><span class="nav-dot" style="background:var(--fl)"></span>FL 产品</a>
    <a href="#funlab-fb" class="nav-link fl"><span class="nav-dot" style="background:var(--fl)"></span>FL Meta</a>
    <a href="#funlab-google" class="nav-link fl"><span class="nav-dot" style="background:var(--fl)"></span>FL Google Ads</a>
    <a href="#funlab-seo" class="nav-link fl"><span class="nav-dot" style="background:var(--fl)"></span>FL SEO</a>
    <a href="#kol" class="nav-link">KOL</a>
    <a href="#complaints" class="nav-link">客诉 KPI</a>
    <a href="#seo-prod" class="nav-link">SEO 产能</a>
    <a href="#lighthouse" class="nav-link">Lighthouse</a>
    <a href="#action" class="nav-link">下周任务</a>
  </div>
</div>

<!-- ===== 01 OVERVIEW ===== -->
<div class="section" id="overview">
  <div class="section-header"><span class="section-tag">01</span><span class="section-title">双品牌核心指标总览</span><div class="section-line"></div></div>

  <div class="shopify-callout" style="background: linear-gradient(135deg, rgba(255,157,0,0.10) 0%, rgba(255,179,71,0.06) 100%); border-color: rgba(255,157,0,0.18);">
    <div style="font-family:'DM Mono',monospace;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);margin-bottom:14px;">Powkong · Shopify 后台</div>
    <div class="row">
      <div><div class="s-label">销售额 (Gross)</div><div class="s-val" style="color:var(--pw)">{{ section_01.shopify_pk.gross }}</div><div class="s-delta num-amber">{{ section_01.shopify_pk.orders }} 单</div></div>
      <div><div class="s-label">已发货</div><div class="s-val">{{ section_01.shopify_pk.fulfilled }}</div><div class="s-delta" style="color:var(--muted)">{{ section_01.shopify_pk.fulfilled_pct }}</div></div>
      <div><div class="s-label">退款数</div><div class="s-val {% if section_01.shopify_pk.refund_count == 0 %}num-green{% else %}num-amber{% endif %}">{{ section_01.shopify_pk.refund_count }}</div><div class="s-delta {% if section_01.shopify_pk.refund_count == 0 %}num-green{% else %}num-amber{% endif %}">退款率 {{ section_01.shopify_pk.refund_rate }}</div></div>
      <div><div class="s-label">折扣总额</div><div class="s-val">{{ section_01.shopify_pk.discount_total }}</div><div class="s-delta" style="color:var(--muted)">{{ section_01.shopify_pk.discount_orders }} 单使用</div></div>
      <div><div class="s-label">异常订单</div><div class="s-val {% if section_01.shopify_pk.abnormal_cancelled == 0 and section_01.shopify_pk.abnormal_dup_email == 0 %}num-green{% else %}num-amber{% endif %}">{{ section_01.shopify_pk.abnormal_cancelled }}</div><div class="s-delta" style="color:var(--muted)">{% if section_01.shopify_pk.abnormal_dup_email > 0 %}{{ section_01.shopify_pk.abnormal_dup_email }} 重复邮箱{% else %}无重复邮箱{% endif %}</div></div>
    </div>
  </div>

  <div class="shopify-callout" style="background: linear-gradient(135deg, rgba(153,0,255,0.10) 0%, rgba(252,103,138,0.06) 100%); border-color: rgba(153,0,255,0.18);">
    <div style="font-family:'DM Mono',monospace;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);margin-bottom:14px;">FUNLAB · Shopline 后台</div>
    <div class="row">
      <div><div class="s-label">销售额</div><div class="s-val" style="color:var(--fl)">{{ section_01.shopline_fl.gross }}</div><div class="s-delta num-amber">{{ section_01.shopline_fl.orders }} 单</div></div>
      <div><div class="s-label">已付款</div><div class="s-val">{{ section_01.shopline_fl.fulfilled }}</div><div class="s-delta" style="color:var(--muted)">{{ section_01.shopline_fl.fulfilled_pct }}</div></div>
      <div><div class="s-label">退款数</div><div class="s-val {% if section_01.shopline_fl.refund_count == 0 %}num-green{% else %}num-amber{% endif %}">{{ section_01.shopline_fl.refund_count }}</div><div class="s-delta {% if section_01.shopline_fl.refund_count == 0 %}num-green{% else %}num-amber{% endif %}">退款率 {{ section_01.shopline_fl.refund_rate }}</div></div>
      <div><div class="s-label">异常订单</div><div class="s-val {% if section_01.shopline_fl.abnormal_dup_email > 0 %}num-amber{% else %}num-green{% endif %}">{{ section_01.shopline_fl.abnormal_dup_email }}</div><div class="s-delta {% if section_01.shopline_fl.abnormal_dup_email > 0 %}num-amber{% else %}num-green{% endif %}">{% if section_01.shopline_fl.abnormal_dup_email > 0 %}重复邮箱 24h{% else %}无重复邮箱{% endif %}</div></div>
      <div><div class="s-label">客单价</div><div class="s-val">{{ section_01.shopline_fl.aov }}</div><div class="s-delta" style="color:var(--muted)">PK 客单 {{ section_01.shopify_pk.aov }}</div></div>
    </div>
  </div>

  <div class="chart-card">
    <div class="chart-title">GA4 双品牌对比</div>
    <table class="diff-table">
      <thead><tr><th>指标</th><th>Powkong (本周)</th><th>FUNLAB (本周)</th><th>差异</th></tr></thead>
      <tbody>
        {% for row in section_01.ga4_compare %}
        <tr><td>{{ row.label }}</td><td class="mono">{{ row.pk }}</td><td class="mono">{{ row.fl }}</td><td class="{{ row.diff_class }}">{{ row.diff }}</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <div class="callout">
    <div class="callout-title">⚡ 跨平台口径差异</div>
    <div class="callout-body">
      <strong>Powkong</strong>: Shopify {{ section_01.cross_platform.pk_shopify_money }} vs GA4 {{ section_01.cross_platform.pk_ga4_money }}，差异 {{ section_01.cross_platform.pk_diff_pct }} (折扣/税费/归因窗口)，财务以 Shopify 为准。<br>
      <strong>FUNLAB</strong>: Shopline {{ section_01.cross_platform.fl_shopline_money }} vs GA4 {{ section_01.cross_platform.fl_ga4_money }}，差异 {{ section_01.cross_platform.fl_diff_pct }}{% if section_01.cross_platform.fl_diff_pct != '—' %}，归因模型差异大，需查像素配置{% endif %}。
    </div>
  </div>
  {% if insights_html.get('01') %}<div class="chart-card" style="margin-top:16px;"><div class="chart-title">AI 洞察</div>{{ insights_html['01'] | safe }}</div>{% endif %}
</div>

<!-- ===== 02 POWKONG GA4 ===== -->
<div class="section" id="powkong">
  <div class="section-header"><span class="section-tag">02</span><span class="section-title brand-pw">Powkong · 独立站</span><div class="section-line"></div></div>
  {% if section_02._missing %}
  <div class="note-box"><strong>⚠️ 数据缺口</strong>: GA4 PK collector 失败，本段无数据。</div>
  {% else %}
  <div class="metrics-grid" style="margin-bottom:20px;">
    {% for m in section_02.metrics %}
    <div class="metric-card {{ m.color }}"><div class="m-label">{{ m.label }}</div><div class="m-value{% if m.value_size %} {{ m.value_size }}{% endif %}">{{ m.value }}</div>{% if m.sub %}<div class="m-sub">{{ m.sub }}</div>{% endif %}</div>
    {% endfor %}
  </div>
  {% endif %}

  <div class="two-col">
    <div class="chart-card">
      <div class="chart-title">流量来源分布 (sessions / 占比)</div>
      <div class="chart-subtitle">总会话 {{ section_02.total_sessions }} · 来源已细分占比</div>
      {% for c in section_02.channels %}
      <div class="bar-row"><div class="bar-label">{{ c.label }}</div><div class="bar-bg"><div class="bar-fill" style="width:{{ c.bar_pct }}%;background:{{ c.color_var }};opacity:{{ c.opacity }};"></div></div><div class="bar-val">{{ c.sessions }} · {{ c.pct }}</div></div>
      {% endfor %}
      <div style="margin-top:10px;padding-top:8px;border-top:1px solid var(--border);font-size:11px;color:var(--muted);">📊 Top 6 流量来源占比 · 数据来自 GA4 sessionDefaultChannelGroup</div>
    </div>
    <div class="chart-card">
      <div class="chart-title">电商漏斗 (会话 → 购买)</div>
      <div class="funnel-step"><div class="funnel-label">会话</div><div class="funnel-bg"><div class="funnel-fill" style="width:100%;background:rgba(255,157,0,0.3);color:#fde7c8;">{{ section_02.funnel.sessions }} · 100%</div></div><div class="funnel-num">{{ section_02.funnel.sessions }}</div></div>
      <div class="funnel-step"><div class="funnel-label">加购</div><div class="funnel-bg"><div class="funnel-fill" style="width:{{ section_02.funnel.atc_pct_num | round(2) }}%;min-width:110px;background:rgba(255,157,0,0.5);color:#fde7c8;">{{ section_02.funnel.add_to_cart }} · {{ section_02.funnel.atc_pct }}</div></div><div class="funnel-num">{{ section_02.funnel.add_to_cart }}</div></div>
